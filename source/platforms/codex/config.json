          "effort": "high"
        },
        "odysseus": {
          "model": "gpt-5.5",
          "effort": "medium"
        }
      }
    }
  },
  "doctor": {
    "reject_when": [
      "features.fast_mode == true",
      "features.unified_exec == true",
      "unified_exec == true",
      "features.multi_agent == true",
      "subscription not in allowed"
    ]
  },
  "user_config": {
    "analytics": {
      "enabled": false
    },
    "approval_policy": "on-request",
    "approvals_reviewer": "auto_review",
    "check_for_update_on_startup": true,
