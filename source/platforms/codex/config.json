    "pro-20": {
      "capacity_class": "pro-20",
      "agents": {
        "atalanta": {
          "model": "gpt-5.4-mini",
          "effort": "medium"
        },
        "athena": {
          "model": "gpt-5.4",
          "effort": "high"
        },
        "calliope": {
          "model": "gpt-5.4-mini",
          "effort": "medium"
        },
        "hephaestus": {
          "model": "gpt-5.3-codex",
          "effort": "high"
