{
  "id": "staged-secret-guard",
  "opencode": {
    "gitHooks": [
      {
        "hook": "pre-commit",
        "kind": "staged-diff-pattern-block",
        "label": "for potential secrets",
        "patterns": [
          "AKIA[0-9A-Z]{16}",
          "ghp_[a-zA-Z0-9]{36}",
          "gho_[a-zA-Z0-9]{36}",
          "ghs_[a-zA-Z0-9]{36}",
          "ghr_[a-zA-Z0-9]{36}",
          "-----BEGIN.*PRIVATE KEY-----",
          "password[[:space:]]*=[[:space:]]*['\\\"][^'\\\"]+['\\\"]",
          "api_key[[:space:]]*=[[:space:]]*['\\\"][^'\\\"]+['\\\"]",
          "secret[[:space:]]*=[[:space:]]*['\\\"][^'\\\"]+['\\\"]"
        ],
        "message": "Potential secret detected in staged changes."
      },
      {
        "hook": "pre-commit",
        "kind": "staged-path-block",
        "label": "for .env files",
        "pattern": "\\.env",
        "message": ".env files should not be committed."
      }
    ]
  },
  "category": "vcs_gate"
}
