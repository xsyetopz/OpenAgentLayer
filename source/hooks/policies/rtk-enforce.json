{
  "id": "rtk-enforce",
  "script": "pre/rtk-enforce.mjs",
  "claude": {
    "event": "PreToolUse",
    "matcher": "Bash",
    "timeout": 10
  },
  "codex": {
    "event": "PreToolUse",
    "matcher": "Bash",
    "timeout": 10
  },
  "copilot": {
    "event": "preToolUse",
    "timeout": 10
  },
  "opencode": {
    "plugin": {
      "event": "tool.execute.before",
      "tools": [
        "bash"
      ],
      "field": "command",
      "kind": "rtk-rewrite",
      "message": "openagentsbtw requires RTK for this bash command when RTK.md is present"
    }
  },
  "category": "execution_guard"
}
