{
  "id": "bash-guard",
  "script": "pre/bash-guard.mjs",
  "claude": {
    "event": "PreToolUse",
    "matcher": "Bash",
    "timeout": 10
  },
  "codex": {
    "event": "PreToolUse",
    "matcher": "Bash",
    "timeout": 10
  },
  "copilot": {
    "event": "preToolUse",
    "timeout": 10
  },
  "opencode": {
    "plugin": {
      "event": "tool.execute.before",
      "tools": [
        "bash"
      ],
      "field": "command",
      "message": "openagentsbtw blocked a dangerous bash command",
      "patterns": [
        "/\\brm\\s+-rf\\s+\\/$/",
        "/\\bgit\\s+add\\s+\\.\\b/",
        "/\\bgit\\s+commit\\b/",
        "/\\bgit\\s+push\\b/"
      ]
    }
  },
  "category": "execution_guard"
}
