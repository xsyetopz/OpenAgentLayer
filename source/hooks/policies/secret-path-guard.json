{
  "id": "secret-path-guard",
  "script": "pre/secret-path-guard.mjs",
  "copilot": {
    "event": "preToolUse",
    "timeout": 10
  },
  "opencode": {
    "plugin": {
      "event": "tool.execute.before",
      "tools": [
        "read",
        "edit",
        "write"
      ],
      "field": "filePath",
      "message": "openagentsbtw blocked access to a secret-like file",
      "patterns": [
        "/(^|\\/)(\\.env($|\\.)|.*\\.(pem|key))$/i"
      ]
    }
  },
  "category": "input_guard"
}
