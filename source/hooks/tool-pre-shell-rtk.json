{
  "$schema": "../schema/hook.schema.json",
  "id": "tool-pre-shell-rtk",
  "category": "tool-pre",
  "description": "Require RTK command shape when RTK policy is active.",
  "intent": "Route shell commands through RTK so policy compression and command rewriting stay active.",
  "handler": {
    "kind": "command",
    "runtime_path": "source/hooks/runtime/tool-pre-shell-rtk.mjs"
  },
  "supported_platforms": {
    "claude": {
      "events": [
        "PreToolUse"
      ],
      "input_adapter": "claude-pretooluse-shell",
      "output_adapter": "claude-block-or-allow",
      "matcher": "Bash",
      "timeout_seconds": 10
    },
    "codex": {
      "events": [
        "PreToolUse"
      ],
      "input_adapter": "codex-pretooluse-shell",
      "output_adapter": "codex-block-or-allow",
      "matcher": "^Bash$",
      "status_message": "Checking RTK shell policy",
      "timeout_seconds": 10
    }
  },
  "unsupported_platforms": {
    "opencode": "Hook payload parity not proven in this wave."
  }
}
