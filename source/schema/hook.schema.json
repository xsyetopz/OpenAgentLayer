{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "category",
    "description",
    "intent",
    "handler",
    "supported_platforms",
    "unsupported_platforms"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z]+-[a-z]+-.+"
    },
    "category": {
      "enum": [
        "tool-pre",
        "tool-post",
        "tool-fail",
        "prompt-submit",
        "session-start",
        "agent-start",
        "compact-pre"
      ]
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "intent": {
      "type": "string",
      "minLength": 1
    },
    "handler": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "runtime_path"
      ],
      "properties": {
        "kind": {
          "enum": [
            "command",
            "script",
            "plugin",
            "config-only"
          ]
        },
        "runtime_path": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "supported_platforms": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "events",
          "input_adapter",
          "output_adapter"
        ],
        "properties": {
          "events": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "input_adapter": {
            "type": "string",
            "minLength": 1
          },
          "output_adapter": {
            "type": "string",
            "minLength": 1
          },
          "matcher": {
            "type": "string"
          },
          "status_message": {
            "type": "string",
            "minLength": 1
          },
          "timeout_seconds": {
            "type": "integer",
            "minimum": 1
          }
        }
      }
    },
    "unsupported_platforms": {
      "type": "object",
      "additionalProperties": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
