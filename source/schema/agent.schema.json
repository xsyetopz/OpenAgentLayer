{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "display_name",
    "role",
    "model_route",
    "platforms",
    "prompt_path"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "id": {
      "enum": [
        "athena",
        "hermes",
        "hephaestus",
        "nemesis",
        "atalanta",
        "calliope",
        "odysseus"
      ]
    },
    "display_name": {
      "type": "string",
      "minLength": 1
    },
    "role": {
      "type": "string",
      "minLength": 1
    },
    "model_route": {
      "enum": [
        "plan",
        "research",
        "implement",
        "debug",
        "review",
        "utility",
        "classify_contract"
      ]
    },
    "platforms": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "enum": [
          "codex",
          "claude",
          "opencode"
        ]
      }
    },
    "prompt_path": {
      "type": "string",
      "pattern": "^source/agents/prompts/[a-z]+\\.md$"
    }
  }
}
