{
	"name": "openagentlayer",
	"version": "0.1.3-beta.4",
	"private": true,
	"type": "module",
	"workspaces": [
		"packages/*"
	],
	"scripts": {
		"lint": "bunx biome check . --error-on-warnings --max-diagnostics 16384",
		"format": "bunx biome format . --write --max-diagnostics 16384",
		"biome:check": "bunx biome check . --error-on-warnings --max-diagnostics 16384",
		"biome:lint": "bunx biome lint . --max-diagnostics 16384",
		"biome:lint:fix": "bunx biome lint . --write --max-diagnostics 16384",
		"biome:fix": "bunx biome check . --write --max-diagnostics 16384",
		"biome:format": "bunx biome format . --write --max-diagnostics 16384",
		"accept": "bun packages/cli/src/main.ts accept",
		"check": "bun packages/cli/src/main.ts check",
		"deploy": "bun packages/cli/src/main.ts deploy",
		"bin": "bun packages/cli/src/main.ts bin",
		"uninstall": "bun packages/cli/src/main.ts uninstall",
		"plugins": "bun packages/cli/src/main.ts plugins",
		"render": "bun packages/cli/src/main.ts render",
		"preview": "bun packages/cli/src/main.ts preview",
		"features": "bun packages/cli/src/main.ts features",
		"roadmap:evidence": "bun packages/cli/src/main.ts roadmap-evidence",
		"rtk-gain": "bun packages/cli/src/main.ts rtk-gain",
		"test": "bun test packages/*/__tests__/*.test.ts tests/*.test.ts",
		"test:unit": "bun test packages/*/__tests__/*.test.ts",
		"test:e2e": "bun test tests/*.test.ts",
		"toolchain": "bun packages/cli/src/main.ts toolchain",
		"schemas:sync": "bun scripts/sync-provider-schemas.mjs",
		"schemas:check": "bun scripts/sync-provider-schemas.mjs --check"
	},
	"dependencies": {
		"@clack/prompts": "^1.3.0",
		"@openagentlayer/accept": "workspace:*",
		"@openagentlayer/adapter": "workspace:*",
		"@openagentlayer/artifact": "workspace:*",
		"@openagentlayer/cli": "workspace:*",
		"@openagentlayer/deploy": "workspace:*",
		"@openagentlayer/manifest": "workspace:*",
		"@openagentlayer/plugins": "workspace:*",
		"@openagentlayer/policy": "workspace:*",
		"@openagentlayer/runtime": "workspace:*",
		"@openagentlayer/source": "workspace:*",
		"@openagentlayer/toolchain": "workspace:*",
		"@opencode-ai/plugin": "1.14.33",
		"commander": "^14.0.3",
		"@openagentlayer/setup": "workspace:*"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.14",
		"ajv": "^8.20.0",
		"bun-types": "1.3.13"
	},
	"engines": {
		"node": ">=24.14.1"
	}
}
