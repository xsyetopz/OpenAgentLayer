{
  "name": "openagentlayer",
  "devDependencies": {
    "@openagentlayer/testkit": "workspace:*",
    "@biomejs/biome": "2.4.13",
    "ajv": "^8.20.0",
    "bun-types": "1.3.13"
  },
  "engines": {
    "node": ">=24.14.1"
  },
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "bin": {
    "oal": "packages/cli/src/cli.ts"
  },
  "scripts": {
    "oal": "bun packages/cli/src/cli.ts",
    "test": "bun test ./packages ./scripts/e2e",
    "lint": "bunx biome check . --error-on-warnings --max-diagnostics 16384",
    "format": "bunx biome format . --write --max-diagnostics 16384",
    "check": "bun run lint && bun run check:source && bun run test",
    "check:source": "bun packages/cli/src/cli.ts check",
    "e2e": "bun scripts/e2e/run-headless.mjs",
    "e2e:claude": "bun scripts/e2e/claude-headless.mjs",
    "e2e:codex": "bun scripts/e2e/codex-headless.mjs",
    "e2e:opencode": "bun scripts/e2e/opencode-headless.mjs",
    "render": "bun packages/cli/src/cli.ts render --out generated",
    "generate": "bun run render",
    "sync:third-party-skills": "bun scripts/sync-third-party-skills.mjs",
    "biome:check": "bunx biome check . --error-on-warnings --max-diagnostics 16384",
    "biome:lint": "bunx biome lint . --max-diagnostics 16384",
    "biome:lint:fix": "bunx biome lint . --write --max-diagnostics 16384",
    "biome:fix": "bunx biome check . --write --max-diagnostics 16384",
    "biome:format": "bunx biome format . --write --max-diagnostics 16384"
  },
  "type": "module"
}
