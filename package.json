{
	"name": "openagentlayer",
	"version": "0.9.0-beta.1",
	"private": true,
	"type": "module",
	"workspaces": [
		"packages/*"
	],
	"scripts": {
		"biome:check": "bunx biome check . --error-on-warnings --max-diagnostics 16384",
		"biome:check:fix": "bun run biome:check --write",
		"biome:lint": "bunx biome lint . --max-diagnostics 16384",
		"biome:lint:fix": "bun run biome:lint --write",
		"biome:format": "bunx biome format . --write --max-diagnostics 16384",
		"oal:accept": "bun packages/cli/src/main.ts accept",
		"oal:check": "bun packages/cli/src/main.ts check",
		"oal:deploy": "bun packages/cli/src/main.ts deploy",
		"oal:bin": "bun packages/cli/src/main.ts bin",
		"oal:profiles": "bun packages/cli/src/main.ts profiles",
		"oal:state": "bun packages/cli/src/main.ts state",
		"oal:uninstall": "bun packages/cli/src/main.ts uninstall",
		"oal:plugins": "bun packages/cli/src/main.ts plugins",
		"oal:render": "bun packages/cli/src/main.ts render",
		"oal:preview": "bun packages/cli/src/main.ts preview",
		"oal:features": "bun packages/cli/src/main.ts features",
		"oal:roadmap:evidence": "bun packages/cli/src/main.ts roadmap-evidence",
		"oal:rtk-gain": "bun packages/cli/src/main.ts rtk-gain",
		"gitleaks:sync": "bun scripts/sync-gitleaks-rules.mjs",
		"gitleaks:check": "bun scripts/sync-gitleaks-rules.mjs --check",
		"test": "bun test packages/*/__tests__/*.test.ts tests/*.test.ts",
		"test:unit": "bun test packages/*/__tests__/*.test.ts",
		"test:e2e": "bun test tests/*.test.ts",
		"oal:toolchain": "bun packages/cli/src/main.ts toolchain"
	},
	"dependencies": {
		"@clack/prompts": "^1.4.0",
		"@openagentlayer/accept": "workspace:*",
		"@openagentlayer/adapter": "workspace:*",
		"@openagentlayer/artifact": "workspace:*",
		"@openagentlayer/cli": "workspace:*",
		"@openagentlayer/deploy": "workspace:*",
		"@openagentlayer/inspect": "workspace:*",
		"@openagentlayer/manifest": "workspace:*",
		"@openagentlayer/plugins": "workspace:*",
		"@openagentlayer/policy": "workspace:*",
		"@openagentlayer/runtime": "workspace:*",
		"@openagentlayer/source": "workspace:*",
		"@openagentlayer/toolchain": "workspace:*",
		"@opencode-ai/plugin": "1.14.48",
		"commander": "^14.0.3",
		"@openagentlayer/setup": "workspace:*"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.15",
		"bun-types": "1.3.13"
	},
	"engines": {
		"node": ">=24.14.1"
	}
}
