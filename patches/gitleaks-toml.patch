--- a/config/gitleaks.toml
+++ b/config/gitleaks.toml
@@ -3207,3 +3207,53 @@
 regex = '''(?i)[\w.-]{0,50}?(?:zendesk)(?:[ \t\w.-]{0,20})[\s'"]{0,3}(?:=|>|:{1,3}=|\|\||:|=>|\?=|,)[\x60'"\s=]{0,5}([a-z0-9]{40})(?:[\x60'"\s;]|\\[nr]|$)'''
 keywords = ["zendesk"]
 
+
+
+# OAL supplemental rules: keep only patterns absent from upstream Gitleaks.
+[[rules]]
+id = "oal-sensitive-dev-file"
+description = "Detected a sensitive developer credential file path."
+path = '''(?:^|/)(?:\.env(?:\.[^/\s]+)?|\.npmrc|\.pypirc|\.netrc|\.dockercfg|\.aws/(?:credentials|config)|\.kube/config|kubeconfig(?:\.[^/\s]+)?|id_(?:rsa|dsa|ecdsa|ed25519)|service-account(?:-key)?\.json|AuthKey_[A-Z0-9]{10}\.p8)$|\.(?:pem|key|p12|pfx|jks|keystore|mobileprovision|developerprofile)$'''
+
+[[rules]]
+id = "oal-apple-app-store-connect-authkey"
+description = "Detected an App Store Connect AuthKey .p8 private key reference."
+regex = '''\b(AuthKey_[A-Z0-9]{10}\.p8)\b'''
+keywords = ["AuthKey_"]
+
+[[rules]]
+id = "oal-apple-app-specific-password"
+description = "Detected an Apple app-specific password in developer tooling context."
+regex = '''(?i)[\w.-]{0,50}?(?:apple|fastlane|application[\s_-]?specific)(?:[ \t\w.-]{0,30})[\s'"]{0,3}(?:=|>|:{1,3}=|\|\||:|=>|\?=|,)[\x60'"\s=]{0,5}([a-z]{4}-[a-z]{4}-[a-z]{4}-[a-z]{4})(?:[\x60'"\s;]|\\[nr]|$)'''
+keywords = ["apple", "fastlane", "application"]
+
+[[rules]]
+id = "oal-apple-app-store-connect-issuer"
+description = "Detected App Store Connect issuer or key identifiers in Apple Developer automation context."
+regex = '''(?i)[\w.-]{0,50}?(?:app[\s_-]?store[\s_-]?connect|asc|apple)(?:[ \t\w.-]{0,40})(?:issuer[_-]?id|key[_-]?id)[\s'"]{0,3}(?:=|>|:{1,3}=|\|\||:|=>|\?=|,)[\x60'"\s=]{0,5}([0-9a-f-]{36}|[A-Z0-9]{10})(?:[\x60'"\s;]|\\[nr]|$)'''
+keywords = ["appstore", "app_store", "app-store", "asc", "apple"]
+
+[[rules]]
+id = "oal-openrouter-api-key"
+description = "Detected an OpenRouter API key."
+regex = '''\b(sk-or-v1-[A-Za-z0-9_\-]{20,})(?:[\x60'"\s;]|\\[nr]|$)'''
+keywords = ["sk-or-v1"]
+
+[[rules]]
+id = "oal-xai-api-key"
+description = "Detected an xAI API key."
+regex = '''\b(xai-[A-Za-z0-9_\-]{20,})(?:[\x60'"\s;]|\\[nr]|$)'''
+keywords = ["xai-"]
+
+[[rules]]
+id = "oal-mistral-api-key"
+description = "Detected a Mistral API key assignment."
+regex = '''(?i)[\w.-]{0,50}?(?:mistral|MISTRAL_API_KEY)(?:[ \t\w.-]{0,20})[\s'"]{0,3}(?:=|>|:{1,3}=|\|\||:|=>|\?=|,)[\x60'"\s=]{0,5}([A-Za-z0-9]{32,})(?:[\x60'"\s;]|\\[nr]|$)'''
+keywords = ["mistral", "MISTRAL_API_KEY"]
+
+[[rules]]
+id = "oal-database-url-credentials"
+description = "Detected database connection URL credentials absent from upstream Gitleaks coverage."
+regex = '''\b((?:postgres(?:ql)?|redis):\/\/[^\s:@]+:[^\s@]+@[^\s]+)'''
+keywords = ["postgres", "postgresql", "redis"]
+
