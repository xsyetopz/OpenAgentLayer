#!/bin/bash
set -euo pipefail

usage() {
    cat <<'EOF' >&2
Usage: oabtw-codex <mode> [prompt...]

Modes:
  triage      Generated openagentsbtw Codex route
  docs        Generated openagentsbtw Codex route
  desloppify  Generated openagentsbtw Codex route
  handoff     Generated openagentsbtw Codex route
  test        Generated openagentsbtw Codex route
  plan        Generated openagentsbtw Codex route
  accept      Generated openagentsbtw Codex route
  implement   Generated openagentsbtw Codex route
  review      Generated openagentsbtw Codex route
  orchestrate Generated openagentsbtw Codex route
EOF
    exit 1
}

[[ $# -ge 1 ]] || usage

MODE="$1"
shift

if [[ $# -gt 0 ]]; then
    PROMPT="$*"
elif [[ ! -t 0 ]]; then
    PROMPT="$(cat)"
else
    usage
fi

PROFILE="openagentsbtw"
SYSTEM_PROMPT=""

case "$MODE" in
    triage)
        PROFILE="openagentsbtw-codex-mini"
        SYSTEM_PROMPT="Use openagentsbtw. Route this through hermes-style exploration on the codex-mini profile. Keep the result concise, evidence-driven, and scoped to bounded search or classification."
        ;;
    docs)
        PROFILE="openagentsbtw-codex-mini"
        SYSTEM_PROMPT="Use openagentsbtw. Route this through calliope-style documentation work on the codex-mini profile. Keep prose factual, terse, and free of filler."
        ;;
    desloppify)
        PROFILE="openagentsbtw-codex-mini"
        SYSTEM_PROMPT="Use openagentsbtw. Route this through calliope plus the desloppify skill on the codex-mini profile. Remove AI filler, sycophancy, narrating comments, and optional-offer boilerplate."
        ;;
    handoff)
        PROFILE="openagentsbtw-codex-mini"
        SYSTEM_PROMPT="Use openagentsbtw. Route this through calliope for writing and hermes for exact repo state on the codex-mini profile. Keep the summary compact and operational."
        ;;
    test)
        PROFILE="openagentsbtw-codex-mini"
        SYSTEM_PROMPT="Use openagentsbtw. Route this through atalanta-style targeted validation on the codex-mini profile. Run and analyze; do not drift into implementation."
        ;;
    plan)
        PROFILE="openagentsbtw"
        SYSTEM_PROMPT="Use openagentsbtw. Route planning through athena-style architecture analysis on the main profile. Treat native /plan as reasoning mode only, not role selection. Lead with the recommendation and keep the plan concrete."
        ;;
    accept)
        PROFILE="openagentsbtw-accept-edits"
        SYSTEM_PROMPT="Use openagentsbtw. Route implementation through hephaestus-style execution on the sandboxed auto-accept profile. This mode keeps workspace-write sandboxing but does not pause for edit approvals. Complete the requested work, avoid placeholders, avoid unnecessary fallbacks, and keep comments to non-obvious why."
        ;;
    implement)
        PROFILE="openagentsbtw"
        SYSTEM_PROMPT="Use openagentsbtw. Route implementation through hephaestus-style execution on the main profile. Complete the requested work, avoid placeholders, avoid unnecessary fallbacks, and keep comments to non-obvious why."
        ;;
    review)
        PROFILE="openagentsbtw"
        SYSTEM_PROMPT="Use openagentsbtw. Route review through nemesis-style analysis on the main profile. Lead with findings, cite evidence, and focus on correctness, regressions, security, and missing tests."
        ;;
    orchestrate)
        PROFILE="openagentsbtw"
        SYSTEM_PROMPT="Use openagentsbtw. Route multi-step coordination through odysseus-style orchestration on the main profile. Delegate only bounded work and track step ownership explicitly."
        ;;
    *)
        usage
        ;;
esac

exec codex exec --profile "$PROFILE" "${SYSTEM_PROMPT}

Task:
${PROMPT}"
