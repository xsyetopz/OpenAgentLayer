#!/usr/bin/env node
/**
 * Stream Guard -- Terminal PTY Proxy (Layer 4)
 *
 * Wraps any command (typically `claude`) in a pseudo-terminal and redacts
 * secrets from stdout in real-time before they reach the terminal/OBS.
 *
 * Zero external dependencies -- uses node:child_process with pipe-based
 * interception and a flush timer to avoid buffering hangs.
 */

import { spawn } from "node:child_process";
import { existsSync, readFileSync } from "node:fs";
import { join, resolve } from "node:path";

const DEFAULT_ENV_FILES = [
	".env",
	".env.local",
	".env.development",
	".env.production",
];
const DEFAULT_SAFE_PREFIXES = [
	"PUBLIC_",
	"NEXT_PUBLIC_",
	"VITE_",
	"REACT_APP_",
	"EXPO_PUBLIC_",
];
const DEFAULT_MIN_LENGTH = 8;
const FLUSH_INTERVAL_MS = 50;

const SECRET_PATTERNS = [
	{
		name: "Generic API Key",
		regex:
			/(?:api_?key|api_?secret|secret_?key|auth_?token|access_?key|passwd|password)\s*[:=]\s*["']?([^\s"']{8,})["']?/gi,
	},
	{ name: "OpenAI Key", regex: /sk-[a-z0-9-]{20,}/gi },
	{ name: "OpenAI Project Key", regex: /sk-proj-[a-zA-Z0-9-]{20,}/g },
	{ name: "AWS Access Key", regex: /AKIA[0-9A-Z]{16}/g },
	{ name: "GitHub Token", regex: /gh[pous]_[A-Za-z0-9_]{36,}/g },
	{ name: "GitHub Fine-grained PAT", regex: /github_pat_[A-Za-z0-9_]{22,}/g },
	{ name: "JWT", regex: /eyJ[A-Za-z0-9_-]{10,}\.[A-Za-z0-9_-]{10,}/g },
	{ name: "Google API Key", regex: /AIza[0-9A-Za-z_-]{35}/g },
	{ name: "Slack Token", regex: /xox[bpras]-[0-9a-zA-Z-]{10,}/g },
	{ name: "Private Key", regex: /-----BEGIN (?:RSA |EC )?PRIVATE KEY-----/g },
	{ name: "Anthropic Key", regex: /sk-ant-[a-z0-9-]{20,}/gi },
	{ name: "Stripe Secret", regex: /sk_live_[a-zA-Z0-9]{24,}/g },
	{ name: "Stripe Restricted", regex: /rk_live_[a-zA-Z0-9]{24,}/g },
	{ name: "bun Token", regex: /bun_[a-zA-Z0-9]{36,}/g },
	{ name: "SendGrid Key", regex: /SG\.[a-zA-Z0-9_-]{22}\.[a-zA-Z0-9_-]{43}/g },
	{ name: "Twilio Key", regex: /SK[a-f0-9]{32}/g },
	{
		name: "Database URL",
		regex: /(?:postgres|mysql|mongodb(?:\+srv)?):\/\/[^:]+:[^@\s]+@[^\s]+/gi,
	},
	{ name: "Vercel Token", regex: /vercel_[a-zA-Z0-9_-]{24,}/gi },
	{ name: "Supabase Key", regex: /sbp_[a-f0-9]{40,}/g },
];

const PII_PATTERNS = [
	{ name: "Email", regex: /[A-Za-z0-9._%+-]+@[A-Za-z0-9.-]+\.[A-Z]{2,}/gi },
	{ name: "SSN", regex: /\b\d{3}-\d{2}-\d{4}\b/g },
	{ name: "Credit Card", regex: /\b(?:\d{4}[-\s]?){3}\d{4}\b/g },
];

function parseEnvFile(content) {
	const entries = [];
	for (const raw of content.split("\n")) {
		const line = raw.trim();
		if (!line || line.startsWith("#")) continue;
		const eqIdx = line.indexOf("=");
		if (eqIdx < 1) continue;
		const key = line.slice(0, eqIdx).trim();
		let val = line.slice(eqIdx + 1).trim();
		if (
			(val.startsWith('"') && val.endsWith('"')) ||
			(val.startsWith("'") && val.endsWith("'"))
		) {
			val = val.slice(1, -1);
		}
		if (val) entries.push({ key, value: val });
	}
	return entries;
}

function loadConfig() {
	const cwd = process.cwd();
	const paths = [
		join(cwd, ".streamguardrc.json"),
		join(process.env.HOME || "~", ".streamguardrc.json"),
	];
	for (const p of paths) {
		try {
			if (existsSync(p)) {
				return JSON.parse(readFileSync(p, "utf-8"));
			}
		} catch {
			/* skip */
		}
	}
	return {};
}

function loadSecretValues(config) {
	const cwd = process.cwd();
	const envFiles = config.envFiles || DEFAULT_ENV_FILES;
	const minLen = config.minSecretLength || DEFAULT_MIN_LENGTH;
	const safePrefixes = config.safeEnvPrefixes || DEFAULT_SAFE_PREFIXES;

	const values = new Map();

	for (const file of envFiles) {
		const fullPath = resolve(cwd, file);
		try {
			if (!existsSync(fullPath)) continue;
			const entries = parseEnvFile(readFileSync(fullPath, "utf-8"));
			for (const { key, value } of entries) {
				if (safePrefixes.some((pfx) => key.startsWith(pfx))) continue;
				if (value.length >= minLen) {
					values.set(value, key);
				}
			}
		} catch {
			/* skip */
		}
	}
	return values;
}

function buildRedactor(secretMap, customPatterns) {
	const allPatterns = [...SECRET_PATTERNS, ...PII_PATTERNS];

	for (const cp of customPatterns) {
		try {
			const re = new RegExp(cp.regex || cp, "g");
			allPatterns.push({ name: cp.name || "Custom", regex: re });
		} catch {
			/* invalid regex */
		}
	}

	const sortedSecrets = [...secretMap.entries()].sort(
		(a, b) => b[0].length - a[0].length,
	);

	return function redact(text) {
		let result = text;

		for (const [value, name] of sortedSecrets) {
			if (result.includes(value)) {
				result = result.replaceAll(value, `[REDACTED:${name}]`);
			}
		}

		if (result.length <= 1_048_576) {
			for (const { name, regex } of allPatterns) {
				const re = new RegExp(
					regex.source,
					regex.flags.includes("g") ? regex.flags : regex.flags + "g",
				);
				result = result.replace(re, `[REDACTED:${name}]`);
			}
		}

		return result;
	};
}

function createFlushingPipe(inputStream, outputStream, redact) {
	let buffer = "";
	let flushTimer = null;

	function flush() {
		if (buffer) {
			outputStream.write(redact(buffer));
			buffer = "";
		}
		flushTimer = null;
	}

	inputStream.on("data", (chunk) => {
		buffer += chunk.toString();

		const lastNewline = buffer.lastIndexOf("\n");
		if (lastNewline >= 0) {
			const complete = buffer.slice(0, lastNewline + 1);
			buffer = buffer.slice(lastNewline + 1);
			outputStream.write(redact(complete));
		}

		if (flushTimer) clearTimeout(flushTimer);
		if (buffer) {
			flushTimer = setTimeout(flush, FLUSH_INTERVAL_MS);
		}
	});

	return { flush };
}

function main() {
	const args = process.argv.slice(2);

	if (args.length === 0) {
		process.stderr.write(
			"Usage: stream-guard <command> [args...]\n" +
				"  e.g. stream-guard claude\n" +
				"       CCA_STREAM_MODE=1 stream-guard claude\n",
		);
		process.exit(1);
	}

	const config = loadConfig();
	if (config.enabled === false) {
		const child = spawn(args[0], args.slice(1), { stdio: "inherit" });
		child.on("exit", (code) => process.exit(code ?? 1));
		return;
	}

	const secretMap = loadSecretValues(config);
	const redact = buildRedactor(secretMap, config.customPatterns || []);

	const patternCount =
		SECRET_PATTERNS.length +
		PII_PATTERNS.length +
		(config.customPatterns || []).length;
	process.stderr.write(
		`[stream-guard] Active: ${secretMap.size} env values, ${patternCount} patterns\n`,
	);

	const child = spawn(args[0], args.slice(1), {
		stdio: ["pipe", "pipe", "pipe"],
		env: { ...process.env, CCA_STREAM_MODE: "1" },
	});

	if (process.stdin.isTTY) {
		process.stdin.setRawMode(true);
	}
	process.stdin.resume();
	process.stdin.on("data", (chunk) => {
		if (!child.stdin.destroyed) {
			child.stdin.write(chunk);
		}
	});

	const stdoutPipe = createFlushingPipe(child.stdout, process.stdout, redact);
	const stderrPipe = createFlushingPipe(child.stderr, process.stderr, redact);

	child.on("exit", (code) => {
		stdoutPipe.flush();
		stderrPipe.flush();
		if (process.stdin.isTTY) {
			process.stdin.setRawMode(false);
		}
		process.exit(code ?? 0);
	});

	child.on("error", (err) => {
		process.stderr.write(`[stream-guard] Failed to spawn: ${err.message}\n`);
		process.exit(1);
	});

	child.stdin.on("error", () => {});

	process.on("SIGINT", () => child.kill("SIGINT"));
	process.on("SIGTERM", () => child.kill("SIGTERM"));
	process.on("SIGHUP", () => child.kill("SIGHUP"));
}

main();
