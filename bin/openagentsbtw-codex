#!/bin/bash
set -euo pipefail

usage() {
    cat <<'EOF' >&2
Usage: openagentsbtw-codex <mode> [prompt...]

Modes:
  triage      Generated openagentsbtw Codex route
  explore     Generated openagentsbtw Codex route
  trace       Generated openagentsbtw Codex route
  debug       Generated openagentsbtw Codex route
  deepwiki    Generated openagentsbtw Codex route
  docs        Generated openagentsbtw Codex route
  desloppify  Generated openagentsbtw Codex route
  handoff     Generated openagentsbtw Codex route
  test        Generated openagentsbtw Codex route
  plan        Generated openagentsbtw Codex route
  accept      Generated openagentsbtw Codex route
  implement   Generated openagentsbtw Codex route
  review      Generated openagentsbtw Codex route
  orchestrate Generated openagentsbtw Codex route
  memory      Inspect or manage openagentsbtw Codex memory

Memory commands:
  openagentsbtw-codex memory show [path]
  openagentsbtw-codex memory forget-project [path]
  openagentsbtw-codex memory prune
EOF
    exit 1
}

[[ $# -ge 1 ]] || usage

MODE="$1"
shift

if [[ "$MODE" == "memory" ]]; then
    [[ $# -ge 1 ]] || usage
    exec node "$HOME/.codex/openagentsbtw/hooks/scripts/session/memory-manage.mjs" "$@"
fi

if [[ $# -gt 0 ]]; then
    PROMPT="$*"
elif [[ ! -t 0 ]]; then
    PROMPT="$(cat)"
else
    usage
fi

PLUGIN_INVOKE=""
if [[ -f "$HOME/.codex/plugins/openagentsbtw/.codex-plugin/plugin.json" ]]; then
    PLUGIN_INVOKE=$'$openagentsbtw\n\n'
fi

PROFILE="openagentsbtw"
SYSTEM_PROMPT=""
CODEX_CONFIG_ARGS=()

case "$MODE" in
    triage)
        PROFILE="openagentsbtw-codex-mini"
        SYSTEM_PROMPT="Use openagentsbtw. Route this through hermes-style exploration on the codex-mini profile. Keep the result concise, evidence-driven, and scoped to bounded search or classification."
        ;;
    explore)
        PROFILE="openagentsbtw-codex-mini"
        SYSTEM_PROMPT="Use openagentsbtw plus the explore skill. Route this through hermes-style repo exploration on the codex-mini profile. Map architecture, entrypoints, ownership, and likely change points. Keep the result concise and evidence-driven."
        ;;
    trace)
        PROFILE="openagentsbtw-codex-mini"
        SYSTEM_PROMPT="Use openagentsbtw plus the trace skill. Route this through hermes-style tracing on the codex-mini profile. Follow a symbol, dependency path, or data flow end-to-end and report upstream, downstream, and impact points."
        ;;
    debug)
        PROFILE="openagentsbtw-codex-mini"
        SYSTEM_PROMPT="Use openagentsbtw plus the debug skill. Route this through hermes-style investigation on the codex-mini profile. Narrow the failure, separate verified evidence from suspicion, and do not drift into implementation."
        ;;
    deepwiki)
        PROFILE="openagentsbtw-codex-mini"
        SYSTEM_PROMPT="Use openagentsbtw. Route this through hermes-style exploration on the codex-mini profile. Use DeepWiki MCP tools first for public GitHub repository understanding, then verify exact local file or line claims with repo reads before stating them. Keep the result concise, evidence-driven, and scoped to exploration."
        CODEX_CONFIG_ARGS+=(-c "model = \"gpt-5.1-codex-mini\"")
        CODEX_CONFIG_ARGS+=(-c "model_reasoning_effort = \"low\"")
        if ! grep -Eq '^[[:space:]]*\[mcp_servers\.deepwiki\]' "$HOME/.codex/config.toml" 2>/dev/null; then
            echo "DeepWiki is not configured. Reinstall with --codex-deepwiki or use triage." >&2
            exit 1
        fi
        if [[ ! -d .git ]] || ! git remote get-url origin 2>/dev/null | grep -Eq '^https://github\.com/|^git@github\.com:'; then
            echo "DeepWiki mode expects a GitHub repository. Use triage for local-only or non-GitHub repos." >&2
            exit 1
        fi
        ;;
    docs)
        PROFILE="openagentsbtw-codex-mini"
        SYSTEM_PROMPT="Use openagentsbtw. Route this through calliope-style documentation work on the codex-mini profile. Keep prose factual, terse, and free of filler."
        ;;
    desloppify)
        PROFILE="openagentsbtw-codex-mini"
        SYSTEM_PROMPT="Use openagentsbtw. Route this through calliope plus the desloppify skill on the codex-mini profile. Remove AI filler, sycophancy, narrating comments, and optional-offer boilerplate."
        ;;
    handoff)
        PROFILE="openagentsbtw-codex-mini"
        SYSTEM_PROMPT="Use openagentsbtw. Route this through calliope for writing and hermes for exact repo state on the codex-mini profile. Keep the summary compact and operational."
        ;;
    test)
        PROFILE="openagentsbtw-codex-mini"
        SYSTEM_PROMPT="Use openagentsbtw. Route this through atalanta-style targeted validation on the codex-mini profile. Run and analyze; do not drift into implementation."
        ;;
    plan)
        PROFILE="openagentsbtw"
        SYSTEM_PROMPT="Use openagentsbtw. Route planning through athena-style architecture analysis on the main profile. Treat native /plan as reasoning mode only, not role selection. Lead with the recommendation and keep the plan concrete."
        ;;
    accept)
        PROFILE="openagentsbtw-accept-edits"
        SYSTEM_PROMPT="Use openagentsbtw. Route implementation through hephaestus-style execution on the sandboxed auto-accept profile. This mode keeps workspace-write sandboxing but does not pause for edit approvals. Complete the requested work, avoid placeholders, avoid unnecessary fallbacks, and keep comments to non-obvious why."
        CODEX_CONFIG_ARGS+=(-c "model = \"gpt-5.2-codex\"")
        CODEX_CONFIG_ARGS+=(-c "model_reasoning_effort = \"high\"")
        ;;
    implement)
        PROFILE="openagentsbtw"
        SYSTEM_PROMPT="Use openagentsbtw. Route implementation through hephaestus-style execution on the main profile. Complete the requested work, avoid placeholders, avoid unnecessary fallbacks, and keep comments to non-obvious why."
        CODEX_CONFIG_ARGS+=(-c "model = \"gpt-5.2-codex\"")
        CODEX_CONFIG_ARGS+=(-c "model_reasoning_effort = \"high\"")
        ;;
    review)
        PROFILE="openagentsbtw"
        SYSTEM_PROMPT="Use openagentsbtw. Route review through nemesis-style analysis on the main profile. Lead with findings, cite evidence, and focus on correctness, regressions, security, and missing tests."
        CODEX_CONFIG_ARGS+=(-c "model = \"gpt-5.2\"")
        CODEX_CONFIG_ARGS+=(-c "model_reasoning_effort = \"high\"")
        ;;
    orchestrate)
        PROFILE="openagentsbtw"
        SYSTEM_PROMPT="Use openagentsbtw. Route multi-step coordination through odysseus-style orchestration on the main profile. Delegate only bounded work and track step ownership explicitly."
        ;;
    *)
        usage
        ;;
esac

exec codex exec --profile "$PROFILE" "${CODEX_CONFIG_ARGS[@]}" "${PLUGIN_INVOKE}${SYSTEM_PROMPT}

Task:
${PROMPT}"
