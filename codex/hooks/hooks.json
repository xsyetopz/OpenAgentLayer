{
  "hooks": {
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.codex/openagentsbtw/hooks/scripts/pre/bash-guard.mjs\"",
            "timeout": 10
          }
        ],
        "matcher": "Bash"
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.codex/openagentsbtw/hooks/scripts/pre/rtk-enforce.mjs\"",
            "timeout": 10
          }
        ],
        "matcher": "Bash"
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.codex/openagentsbtw/hooks/scripts/post/bash-redact.mjs\"",
            "timeout": 10
          }
        ],
        "matcher": "Bash"
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.codex/openagentsbtw/hooks/scripts/session/prompt-queue.mjs\"",
            "timeout": 10
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.codex/openagentsbtw/hooks/scripts/session/prompt-git-context.mjs\"",
            "timeout": 10
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.codex/openagentsbtw/hooks/scripts/session/start-budget.mjs\"",
            "timeout": 10
          }
        ],
        "matcher": "startup|resume"
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.codex/openagentsbtw/hooks/scripts/post/stop-scan.mjs\"",
            "timeout": 15
          }
        ]
      }
    ]
  }
}
