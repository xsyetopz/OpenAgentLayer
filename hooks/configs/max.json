{
	"hooks": {
		"UserPromptSubmit": [
			{
				"hooks": [
					{
						"type": "command",
						"command": "node \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/scripts/session/prompt-git-context.mjs",
						"timeout": 5
					}
				]
			}
		],
		"SessionStart": [
			{
				"hooks": [
					{
						"type": "command",
						"command": "node \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/scripts/session/start-budget.mjs",
						"timeout": 5
					}
				]
			}
		],
		"PreToolUse": [
			{
				"hooks": [
					{
						"type": "command",
						"command": "node \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/scripts/pre/validate-input.mjs",
						"timeout": 5
					}
				]
			},
			{
				"matcher": "Bash",
				"hooks": [
					{
						"type": "command",
						"command": "node \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/scripts/pre/bash-guard.mjs",
						"timeout": 10
					}
				]
			},
			{
				"hooks": [
					{
						"type": "command",
						"command": "node \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/scripts/pre/http-proxy.mjs",
						"timeout": 8
					}
				]
			}
		],
		"PostToolUse": [
			{
				"matcher": "Write|Edit",
				"hooks": [
					{
						"type": "prompt",
						"prompt": "After modifying a file, note any LSP diagnostics in your response. Continue with your current task."
					},
					{
						"type": "command",
						"command": "node \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/scripts/post/write-quality.mjs",
						"timeout": 15
					}
				]
			},
			{
				"matcher": "Bash",
				"hooks": [
					{
						"type": "command",
						"command": "node \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/scripts/post/bash-redact.mjs",
						"timeout": 10
					}
				]
			},
			{
				"matcher": "Bash|Write|Edit",
				"hooks": [
					{
						"type": "command",
						"command": "node \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/scripts/post/http-proxy.mjs",
						"timeout": 8
					}
				]
			}
		],
		"PostToolUseFailure": [
			{
				"hooks": [
					{
						"type": "command",
						"command": "node \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/scripts/post/failure-circuit.mjs",
						"timeout": 5
					}
				]
			}
		],
		"SubagentStop": [
			{
				"matcher": "athena|hephaestus|nemesis|atalanta|calliope|hermes|odysseus",
				"hooks": [
					{
						"type": "prompt",
						"prompt": "Review the agent's deliverable against the original request. List: (1) what was completed with file paths, (2) what remains incomplete. If any part was simplified or deferred, state it explicitly."
					},
					{
						"type": "command",
						"command": "node \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/scripts/post/subagent-scan.mjs",
						"timeout": 15
					},
					{
						"type": "prompt",
						"prompt": "Verify the agent's decision quality: (1) for medium/high-stakes decisions, were 2-3 options with tradeoffs presented? (2) were findings stated with evidence and file:line citations? Flag any decisions made without presenting alternatives."
					}
				]
			}
		],
		"TeammateIdle": [
			{
				"hooks": [
					{
						"type": "command",
						"command": "node \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/scripts/session/teammate-idle-resume.mjs",
						"timeout": 5
					}
				]
			}
		],
		"Notification": [
			{
				"hooks": [
					{
						"type": "command",
						"command": "node \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/scripts/session/notification-audit.mjs",
						"timeout": 3
					}
				]
			}
		],
		"PermissionRequest": [
			{
				"hooks": [
					{
						"type": "command",
						"command": "node \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/scripts/session/permission-audit.mjs",
						"timeout": 3
					}
				]
			}
		],
		"Stop": [
			{
				"hooks": [
					{
						"type": "prompt",
						"prompt": "List every part of the original request and its status: DONE, IN_PROGRESS, or REMAINING. For REMAINING items, state what blocks them."
					},
					{
						"type": "command",
						"command": "node \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/scripts/post/stop-scan.mjs",
						"timeout": 15
					},
					{
						"type": "prompt",
						"prompt": "Before ending: check if significant work was done this session (files modified, decisions made, multi-step tasks in progress). If so, and if .claude/session-handoff.md does not exist or is stale (older than today), suggest: 'Run /cca:session-export to save a handoff for your next session.' Do NOT auto-export — only remind if significant work happened."
					}
				]
			}
		],
		"SessionEnd": [
			{
				"hooks": [
					{
						"type": "command",
						"command": "node \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/scripts/session/end-cleanup.mjs",
						"timeout": 5
					}
				]
			}
		]
	}
}
