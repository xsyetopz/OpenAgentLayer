{
	"hooks": {
		"PostToolUse": [
			{
				"matcher": "Write|Edit",
				"hooks": [
					{
						"type": "prompt",
						"prompt": "Check LSP diagnostics for errors in the file you just modified. Fix any errors before proceeding."
					},
					{
						"type": "command",
						"command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/scripts/auto-format.sh\"",
						"timeout": 10
					}
				]
			}
		]
	}
}
