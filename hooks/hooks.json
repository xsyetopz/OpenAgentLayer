{
  "$schema": "https://raw.githubusercontent.com/anthropics/claude-code/main/schemas/hooks.json",
  "hooks": [
    {
      "event": "SessionStart",
      "type": "command",
      "command": "bash $CLAUDE_PROJECT_ROOT/.claude/hooks/scripts/auto-index.sh check",
      "description": "Check if project index needs refresh on session start",
      "timeout": 5000
    },
    {
      "event": "PostToolUse",
      "type": "command",
      "command": "bash $CLAUDE_PROJECT_ROOT/.claude/hooks/scripts/auto-index.sh mark-dirty",
      "toolNames": ["Write", "Edit"],
      "description": "Mark index as potentially stale after file edits",
      "timeout": 1000
    },
    {
      "event": "PreToolUse",
      "type": "prompt",
      "toolNames": ["Edit", "Write"],
      "prompt": "Check if this file is locked by another agent in .claude/memory/locks.md before editing. If locked, abort and suggest waiting or working on a different file.",
      "description": "Prevent editing locked files"
    },
    {
      "event": "Stop",
      "type": "command",
      "command": "bash $CLAUDE_PROJECT_ROOT/.claude/hooks/scripts/auto-index.sh cleanup-locks",
      "description": "Clean up any locks held by the current agent on session end",
      "timeout": 2000
    }
  ]
}
