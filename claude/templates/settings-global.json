{
	"env": {
		"ANTHROPIC_DEFAULT_HAIKU_MODEL": "__HAIKU_MODEL__",
		"ANTHROPIC_DEFAULT_OPUS_MODEL": "__OPUS_MODEL__",
		"ANTHROPIC_DEFAULT_SONNET_MODEL": "__SONNET_MODEL__",
		"BASH_DEFAULT_TIMEOUT_MS": "30000",
		"CLAUDE_CODE_ADDITIONAL_DIRECTORIES_CLAUDE_MD": "1",
		"CLAUDE_CODE_DISABLE_FAST_MODE": "1",
		"CLAUDE_CODE_DISABLE_FEEDBACK_SURVEY": "1",
		"CLAUDE_CODE_ENABLE_PROMPT_SUGGESTION": "false",
		"CLAUDE_CODE_FILE_READ_MAX_OUTPUT_TOKENS": "128000",
		"CLAUDE_CODE_HIDE_ACCOUNT_INFO": "1",
		"CLAUDE_CODE_MAX_OUTPUT_TOKENS": "64000",
		"CLAUDE_CODE_SAVE_HOOK_ADDITIONAL_CONTEXT": "1",
		"DISABLE_FEEDBACK_COMMAND": "1",
		"DISABLE_TELEMETRY": "1",
		"FORCE_AUTOUPDATE_PLUGINS": "true",
		"MAX_MCP_OUTPUT_TOKENS": "10000"
	},
	"outputStyle": "CCA",
	"permissions": {
		"allow": [
			"Bash(*)",
			"Read(*)",
			"Edit(*)",
			"Write(*)",
			"Search(*)",
			"Plan(*)",
			"List(*)"
		],
		"ask": [
			"Bash(git checkout*)",
			"Bash(git switch*)",
			"Bash(git restore*)",
			"Bash(git clean*)",
			"Bash(git stash drop*)",
			"Bash(git stash pop*)",
			"Bash(git stash clear*)",
			"Bash(git rebase*)",
			"Bash(git merge*)",
			"Bash(git cherry-pick*)",
			"Bash(git revert*)",
			"Bash(git push*)",
			"Bash(git branch -d*)",
			"Bash(git branch -D*)",
			"Bash(git tag -d*)",
			"Bash(git worktree remove*)",
			"Bash(git worktree prune*)",
			"Bash(rm *)",
			"Bash(mv *)",
			"Bash(cp *)",
			"Bash(chmod *)",
			"Bash(chown *)",
			"Bash(ln *)",
			"Bash(docker run*)",
			"Bash(docker exec*)",
			"Bash(docker rm*)",
			"Bash(docker rmi*)",
			"Bash(docker stop*)",
			"Bash(docker compose up*)",
			"Bash(docker compose down*)",
			"Bash(kubectl apply*)",
			"Bash(kubectl delete*)",
			"Bash(kubectl exec*)",
			"Bash(kubectl scale*)",
			"Bash(kubectl rollout*)",
			"Bash(apt install*)",
			"Bash(apt remove*)",
			"Bash(brew install*)",
			"Bash(brew uninstall*)",
			"Bash(bun install -g*)",
			"Bash(pip install*)",
			"Bash(pip3 install*)",
			"Copy(*)",
			"Move(*)",
			"Delete(*)",
			"Download(*)",
			"Upload(*)"
		],
		"deny": [
			"Read(.env)",
			"Read(.env.*)",
			"Read(/etc/shadow)",
			"Read(/etc/passwd)",
			"Read(*id_rsa*)",
			"Read(*id_ed25519*)",
			"Read(**/.ssh/**)",
			"Read(**/.aws/credentials)",
			"Read(*/.git/config)",
			"Read(*/secrets/**)",
			"Read(*/private/**)",
			"Read(*/credentials/**)",
			"Read(C:\\Windows\\System32\\config\\SAM)",
			"Read(/Users/*/Library/Keychains/**)",
			"Read(/Library/Keychains/**)",
			"Read(/Users/*/Library/Application Support/Apple/Developer/*)",
			"Read(/Users/*/Library/MobileDevice/Provisioning Profiles/**)",
			"Read(/Users/*/Library/Preferences/com.apple.security*/*)",
			"Read(/etc/krb5.keytab)",
			"Read(/private/var/db/dslocal/nodes/Default/users/root.plist)",
			"Read(__HOME__/.gnupg/**)",
			"Write(/etc/**)",
			"Write(**/.ssh/**)",
			"Write(**/.aws/credentials)",
			"Write(*/.git/config)",
			"Write(*/secrets/**)",
			"Write(*/private/**)",
			"Write(*/credentials/**)",
			"Write(C:\\Windows\\System32\\**)",
			"Write(/Users/*/Library/Keychains/**)",
			"Write(/Library/Keychains/**)",
			"Write(/Users/*/Library/MobileDevice/Provisioning Profiles/**)",
			"Write(/Users/*/Library/Preferences/com.apple.security*/*)",
			"Write(/etc/krb5.keytab)",
			"Write(/private/var/db/dslocal/nodes/Default/users/root.plist)",
			"Edit(/etc/**)",
			"Edit(C:\\Windows\\System32\\**)",
			"Edit(__HOME__/.bashrc)",
			"Edit(__HOME__/.zshrc)",
			"Edit(__HOME__/.profile)",
			"Edit(/Users/*/Library/Keychains/**)",
			"Edit(/Library/Keychains/**)",
			"Edit(/Users/*/Library/Developer/Xcode/**)",
			"Delete(/etc/**)",
			"Delete(C:\\Windows\\System32\\**)",
			"Delete(**/.ssh/**)",
			"Delete(**/.aws/credentials)",
			"Delete(*/.git/config)",
			"Delete(*/secrets/**)",
			"Delete(*/private/**)",
			"Delete(*/credentials/**)",
			"Delete(/Users/*/Library/Keychains/**)",
			"Delete(/Library/Keychains/**)",
			"Delete(/Users/*/Library/Developer/Xcode/**)",
			"Bash(sudo *)",
			"Bash(dd *)",
			"Bash(mkfs*)",
			"Bash(shutdown*)",
			"Bash(init 0*)",
			"Bash(chmod 777*)",
			"Bash(chown root*)",
			"Bash(poweroff*)",
			"Bash(reboot*)",
			"Bash(format *)",
			"Bash(diskutil eraseDisk*)",
			"Bash(diskutil secureErase*)",
			"Bash(diskutil partitionDisk*)",
			"Bash(rm -rf /*)",
			"Bash(rm -rf ~*)",
			"Bash(git push --force main*)",
			"Bash(git push --force master*)",
			"Bash(git push -f main*)",
			"Bash(git push -f master*)",
			"Bash(git reset --hard*)",
			"Git(push --force*)",
			"Powershell(Remove-Item -Recurse C:\\Windows*)",
			"Powershell(Format-*)",
			"Powershell(Stop-Computer*)",
			"Powershell(Restart-Computer*)",
			"Agent(Explore)",
			"Agent(Plan)",
			"Agent(general-purpose)"
		],
		"defaultMode": "plan"
	},
	"hooks": {
		"PreToolUse": [
			{
				"matcher": "Write|Edit|MultiEdit|NotebookEdit|Read|Bash|WebFetch",
				"hooks": [
					{
						"type": "command",
						"command": "node \"$HOME\"/.claude/hooks/pre-secrets.mjs",
						"timeout": 5
					}
				]
			}
		]
	},
	"disableAllHooks": false,
	"enabledPlugins": {
		"context-mode@context-mode": true,
		"openagentsbtw@openagentsbtw": true
	},
	"extraKnownMarketplaces": {
		"context-mode": {
			"source": {
				"source": "github",
				"repo": "mksglu/context-mode"
			}
		},
		"openagentsbtw": {
			"source": {
				"source": "github",
				"repo": "xsyetopz/openagentsbtw"
			}
		}
	},
	"statusLine": {
		"type": "command",
		"command": "bash __HOME__/.claude/statusline-command.sh"
	},
	"autoUpdatesChannel": "latest",
	"availableModels": [
		"opusplan",
		"opus[1m]",
		"sonnet",
		"haiku"
	],
	"skipWebFetchPreflight": true,
	"alwaysThinkingEnabled": true,
	"terminalImageSupport": true,
	"showClearContextOnPlanAccept": true
}
