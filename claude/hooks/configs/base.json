{
	"hooks": {
		"UserPromptSubmit": [
			{
				"hooks": [
					{
						"type": "command",
						"command": "H=\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/scripts/session/prompt-git-context.mjs; [ -f \"$H\" ] && node \"$H\" || exit 0",
						"timeout": 5
					}
				]
			}
		],
		"SessionStart": [
			{
				"hooks": [
					{
						"type": "command",
						"command": "H=\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/scripts/session/start-budget.mjs; [ -f \"$H\" ] && node \"$H\" || exit 0",
						"timeout": 5
					},
					{
						"type": "command",
						"command": "H=\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/scripts/session/stream-context.mjs; [ -f \"$H\" ] && node \"$H\" || exit 0",
						"timeout": 5
					}
				]
			}
		],
		"PreToolUse": [
			{
				"hooks": [
					{
						"type": "command",
						"command": "H=\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/scripts/pre/validate-input.mjs; [ -f \"$H\" ] && node \"$H\" || exit 0",
						"timeout": 5
					}
				]
			},
			{
				"matcher": "Bash",
				"hooks": [
					{
						"type": "command",
						"command": "H=\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/scripts/pre/bash-guard.mjs; [ -f \"$H\" ] && node \"$H\" || exit 0",
						"timeout": 10
					}
				]
			},
			{
				"matcher": "Bash|Read|Write|Edit",
				"hooks": [
					{
						"type": "command",
						"command": "H=\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/scripts/pre/stream-guard.mjs; [ -f \"$H\" ] && node \"$H\" || exit 0",
						"timeout": 10
					}
				]
			}
		],
		"PostToolUse": [
			{
				"matcher": "Write|Edit",
				"hooks": [
					{
						"type": "prompt",
						"prompt": "After modifying a file, note any LSP diagnostics in your response. Continue with your current task."
					},
					{
						"type": "command",
						"command": "H=\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/scripts/post/write-quality.mjs; [ -f \"$H\" ] && node \"$H\" || exit 0",
						"timeout": 15
					}
				]
			},
			{
				"matcher": "Bash",
				"hooks": [
					{
						"type": "command",
						"command": "H=\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/scripts/post/bash-redact.mjs; [ -f \"$H\" ] && node \"$H\" || exit 0",
						"timeout": 10
					}
				]
			}
		],
		"PostToolUseFailure": [
			{
				"hooks": [
					{
						"type": "command",
						"command": "H=\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/scripts/post/failure-circuit.mjs; [ -f \"$H\" ] && node \"$H\" || exit 0",
						"timeout": 5
					}
				]
			}
		],
		"SubagentStop": [
			{
				"matcher": "athena|hephaestus|nemesis|atalanta|calliope|hermes|odysseus",
				"hooks": [
					{
						"type": "command",
						"command": "H=\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/scripts/post/subagent-scan.mjs; [ -f \"$H\" ] && node \"$H\" || exit 0",
						"timeout": 15
					}
				]
			}
		],
		"Stop": [
			{
				"hooks": [
					{
						"type": "command",
						"command": "H=\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/scripts/post/stop-scan.mjs; [ -f \"$H\" ] && node \"$H\" || exit 0",
						"timeout": 15
					}
				]
			}
		]
	}
}
