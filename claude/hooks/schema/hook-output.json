{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"title": "Claude Code Hook Output",
	"description": "Valid JSON output schema for Claude Code hooks. hookSpecificOutput is event-scoped. Stop/SubagentStop hooks use stderr + exit codes, not hookSpecificOutput.",
	"type": "object",
	"additionalProperties": false,
	"properties": {
		"continue": {
			"type": "boolean",
			"description": "Whether to continue execution"
		},
		"suppressOutput": {
			"type": "boolean",
			"description": "Whether to suppress tool output"
		},
		"stopReason": {
			"type": "string",
			"description": "Reason for stopping"
		},
		"decision": {
			"type": "string",
			"enum": [
				"approve",
				"block"
			],
			"description": "Top-level decision (deprecated -- use hookSpecificOutput)"
		},
		"reason": {
			"type": "string",
			"description": "Reason for the decision"
		},
		"systemMessage": {
			"type": "string",
			"description": "System message to inject"
		},
		"permissionDecision": {
			"type": "string",
			"enum": [
				"allow",
				"deny",
				"ask"
			],
			"description": "Top-level permission decision"
		},
		"hookSpecificOutput": {
			"type": "object",
			"description": "Event-specific output keyed by hookEventName.",
			"oneOf": [
				{
					"type": "object",
					"additionalProperties": false,
					"required": [
						"hookEventName",
						"additionalContext"
					],
					"properties": {
						"hookEventName": {
							"type": "string",
							"const": "SubagentStart"
						},
						"additionalContext": {
							"type": "string"
						}
					}
				},
				{
					"type": "object",
					"additionalProperties": false,
					"required": [
						"hookEventName"
					],
					"properties": {
						"hookEventName": {
							"type": "string",
							"const": "PreToolUse"
						},
						"permissionDecision": {
							"type": "string",
							"enum": [
								"allow",
								"deny",
								"ask"
							]
						},
						"permissionDecisionReason": {
							"type": "string"
						},
						"updatedInput": {
							"type": "object",
							"description": "Modified tool input to use"
						}
					}
				},
				{
					"type": "object",
					"additionalProperties": false,
					"required": [
						"hookEventName",
						"additionalContext"
					],
					"properties": {
						"hookEventName": {
							"type": "string",
							"const": "UserPromptSubmit"
						},
						"additionalContext": {
							"type": "string"
						}
					}
				},
				{
					"type": "object",
					"additionalProperties": false,
					"required": [
						"hookEventName"
					],
					"properties": {
						"hookEventName": {
							"type": "string",
							"const": "PostToolUse"
						},
						"additionalContext": {
							"type": "string"
						}
					}
				},
				{
					"type": "object",
					"additionalProperties": false,
					"required": [
						"hookEventName"
					],
					"properties": {
						"hookEventName": {
							"type": "string",
							"const": "SessionStart"
						},
						"additionalContext": {
							"type": "string"
						}
					}
				}
			]
		}
	}
}
